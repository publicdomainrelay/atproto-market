{
  "lexicon": 1,
  "id": "com.publicdomainrelay.temp.gateway.subscribeComputeEvents",
  "defs": {
    "main": {
      "type": "subscription",
      "description": "Subscribe to lifecycle events for a compute contract. Gateway pushes events as they arrive from the bidder (vm.started, vm.onNetwork, terminated).",
      "parameters": {
        "type": "params",
        "required": ["receiptUri"],
        "properties": {
          "receiptUri": {
            "type": "string",
            "format": "at-uri",
            "description": "AT-URI of the receipt record to subscribe to events for."
          }
        }
      },
      "message": {
        "schema": {
          "type": "union",
          "refs": [
            "#vm_started",
            "#vm_on_network",
            "#terminated",
            "#error"
          ]
        }
      },
      "errors": [
        { "name": "InvalidRequest" },
        { "name": "AuthRequired" }
      ]
    },
    "vm_started": {
      "type": "object",
      "required": ["receiptUri", "timestamp"],
      "properties": {
        "receiptUri": { "type": "string", "format": "at-uri" },
        "timestamp": { "type": "string", "format": "datetime" }
      }
    },
    "vm_on_network": {
      "type": "object",
      "required": ["receiptUri", "address", "timestamp"],
      "properties": {
        "receiptUri": { "type": "string", "format": "at-uri" },
        "address": { "type": "string" },
        "timestamp": { "type": "string", "format": "datetime" }
      }
    },
    "terminated": {
      "type": "object",
      "required": ["receiptUri", "reason", "timestamp"],
      "properties": {
        "receiptUri": { "type": "string", "format": "at-uri" },
        "reason": { "type": "string" },
        "timestamp": { "type": "string", "format": "datetime" }
      }
    },
    "error": {
      "type": "object",
      "required": ["message"],
      "properties": {
        "message": { "type": "string" }
      }
    }
  }
}
