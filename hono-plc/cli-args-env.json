{
  "name": "hono-plc",
  "description": "did:plc directory server",
  "options": {
    "port": {
      "type": "number",
      "description": "Port to listen on",
      "env": "PORT",
      "default": 2587
    },
    "hostname": {
      "type": "string",
      "description": "Hostname to bind to",
      "env": "HOSTNAME",
      "default": "127.0.0.1"
    }
  }
}
